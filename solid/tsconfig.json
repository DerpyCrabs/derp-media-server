{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "jsxImportSource": "solid-js",
    "types": ["vite/client", "bun-types"],
    "paths": {
      "@/*": ["../*"]
    }
  },
  "include": ["./**/*.ts", "./**/*.tsx", "./ambient-modules.d.ts"]
}
