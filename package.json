{
  "name": "derp-media-server",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "bun --watch server/index.ts",
    "build": "vite build",
    "start": "bun run build && NODE_ENV=production bun server/index.ts",
    "lint": "oxlint",
    "lint-errors": "oxlint --quiet",
    "fmt": "oxfmt .",
    "fmt:check": "oxfmt --check .",
    "test": "playwright test",
    "test:unit": "bun test tests/unit/",
    "test:batch": "bun tests/run-batches.ts",
    "test:generate-media": "bun tests/fixtures/generate-media-cache.ts",
    "test:ui": "playwright test --ui",
    "test:headed": "playwright test --headed",
    "prepare": "husky"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@fastify/cookie": "^11.0.2",
    "@fastify/multipart": "^9.4.0",
    "@fastify/static": "^9.0.0",
    "@fontsource-variable/geist": "^5.2.8",
    "@fontsource-variable/geist-mono": "^5.2.7",
    "@tailwindcss/typography": "^0.5.19",
    "@tanstack/react-query": "^5.90.21",
    "archiver": "^7.0.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "fastify": "^5.8.2",
    "lucide-react": "^0.575.0",
    "lucide-static": "^0.575.0",
    "music-metadata": "11.12.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "react-rnd": "^10.5.3",
    "remark-gfm": "^4.0.1",
    "strip-json-comments": "^5.0.3",
    "tailwind-merge": "^3.5.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@fastify/middie": "^9.3.1",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/vite": "^4.2.1",
    "@types/archiver": "^7.0.0",
    "@types/bun": "^1.3.10",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript/native-preview": "^7.0.0-dev.20260312.1",
    "@vitejs/plugin-react": "^5.2.0",
    "husky": "^9.1.7",
    "oxfmt": "^0.35.0",
    "oxlint": "^1.55.0",
    "tailwindcss": "^4.2.1",
    "tw-animate-css": "^1.4.0",
    "vite": "^8.0.0"
  },
  "ignoreScripts": [
    "sharp",
    "unrs-resolver"
  ],
  "trustedDependencies": [
    "sharp",
    "unrs-resolver"
  ]
}
