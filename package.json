{
  "name": "derp-media-server",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "bun --watch server/index.ts",
    "build": "vite build",
    "start": "bun run build && NODE_ENV=production bun server/index.ts",
    "tsgo": "tsgo -p tsconfig.json",
    "lint": "oxlint",
    "lint-errors": "oxlint --quiet",
    "fmt": "oxfmt .",
    "fmt:check": "oxfmt --check .",
    "test": "playwright test",
    "test:unit": "bun test tests/unit/",
    "test:batch": "bun tests/run-batches.ts",
    "test:generate-media": "bun tests/fixtures/generate-media-cache.ts",
    "test:ui": "playwright test --ui",
    "test:headed": "playwright test --headed",
    "prepare": "husky"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/multipart": "^9.4.0",
    "@fastify/static": "^9.0.0",
    "@fontsource-variable/geist": "^5.2.8",
    "@fontsource-variable/geist-mono": "^5.2.7",
    "@tailwindcss/typography": "^0.5.19",
    "@tanstack/solid-query": "^5.91.4",
    "archiver": "^7.0.1",
    "clsx": "^2.1.1",
    "fastify": "^5.8.2",
    "lucide-solid": "0.577.0",
    "lucide-static": "^0.577.0",
    "markdown-it": "^14.1.1",
    "music-metadata": "11.12.3",
    "oxlint-tsgolint": "^0.17.0",
    "solid-js": "^1.9.11",
    "strip-json-comments": "^5.0.3",
    "tailwind-merge": "^3.5.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@fastify/middie": "^9.3.1",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/vite": "^4.2.2",
    "@types/archiver": "^7.0.0",
    "@types/bun": "^1.3.11",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^25.5.0",
    "@typescript/native-preview": "^7.0.0-dev.20260318.1",
    "husky": "^9.1.7",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0",
    "vite": "^8.0.0",
    "vite-plugin-solid": "^2.11.11"
  },
  "ignoreScripts": [
    "sharp",
    "unrs-resolver"
  ],
  "trustedDependencies": [
    "sharp",
    "unrs-resolver"
  ]
}
