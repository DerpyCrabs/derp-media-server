{
  "name": "derp-media-server",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "bun --watch server/index.ts",
    "build": "vite build && bun scripts/generate-service-worker.ts",
    "start": "bun run build && NODE_ENV=production bun server/index.ts",
    "tsgo": "tsgo -p tsconfig.json",
    "lint": "oxlint",
    "lint-errors": "oxlint --quiet",
    "fmt": "oxfmt .",
    "fmt:check": "oxfmt --check .",
    "test": "playwright test",
    "test:unit": "bun test tests/unit/",
    "test:batch": "bun tests/run-batches.ts",
    "benchmark:file-search": "bun scripts/benchmark-file-search.ts",
    "test:generate-media": "bun tests/fixtures/generate-media-cache.ts",
    "test:ui": "playwright test --ui",
    "test:headed": "playwright test --headed",
    "prepare": "husky"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.72",
    "@ai-sdk/provider": "^3.0.10",
    "@fastify/cookie": "^11.0.2",
    "@fastify/multipart": "^10.0.0",
    "@fastify/static": "^9.1.3",
    "@fontsource-variable/geist": "^5.2.9",
    "@fontsource-variable/geist-mono": "^5.2.8",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@openrouter/ai-sdk-provider": "^2.9.1",
    "@tailwindcss/typography": "^0.5.20",
    "@tanstack/solid-query": "^5.101.0",
    "@tanstack/solid-virtual": "^3.13.29",
    "ai": "^6.0.207",
    "archiver": "^8.0.0",
    "clsx": "^2.1.1",
    "fastify": "^5.8.5",
    "lucide-solid": "1.20.0",
    "lucide-static": "^1.20.0",
    "markdown-it": "^14.2.0",
    "music-metadata": "11.13.0",
    "oxlint-tsgolint": "^0.23.0",
    "sharp": "^0.35.1",
    "solid-js": "^1.9.13",
    "strip-json-comments": "^5.0.3",
    "tailwind-merge": "^3.6.0",
    "turndown": "^7.2.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@fastify/middie": "^9.3.2",
    "@playwright/test": "^1.61.0",
    "@tailwindcss/vite": "^4.3.1",
    "@types/archiver": "^8.0.0",
    "@types/bun": "^1.3.14",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^25.9.3",
    "@types/turndown": "^5.0.6",
    "@typescript/native-preview": "^7.0.0-dev.20260616.1",
    "eslint-plugin-solid": "^0.14.5",
    "happy-dom": "^20.10.5",
    "husky": "^9.1.7",
    "oxfmt": "^0.55.0",
    "oxlint": "^1.70.0",
    "tailwindcss": "^4.3.1",
    "tw-animate-css": "^1.4.0",
    "vite": "^8.0.16",
    "vite-plugin-solid": "^2.11.12"
  },
  "ignoreScripts": [
    "sharp",
    "unrs-resolver"
  ],
  "trustedDependencies": [
    "sharp",
    "unrs-resolver"
  ]
}
